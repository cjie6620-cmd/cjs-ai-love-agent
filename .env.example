# 应用对外显示的名称，主要用于日志、文档和服务标识
APP_NAME=AI Love Agent API
# 当前运行环境标识，常用值如 local / dev / test / prod
APP_ENV=local
# 是否开启调试模式，true 会输出更多调试信息
DEBUG=true
# 允许跨域访问的前端来源列表，多个地址用英文逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MySQL 业务库连接串，后端会用它读写会话等结构化数据；MySQL 由外部环境提供，不在 docker-compose 中启动
MYSQL_URL=mysql+pymysql://ai_love:your-mysql-password@127.0.0.1:3306/ai_love
# Redis 连接串，用于缓存、限流和会话短期状态；Redis 由外部环境提供，不在 docker-compose 中启动
REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0
# 向量库连接串，RAG 向量检索会使用这个 PostgreSQL/pgvector 库
VECTOR_DB_URL=postgresql+psycopg://ai_love:change-me@127.0.0.1:5432/ai_love_vector
# docker-compose 中 pgvector 容器的密码，需与 VECTOR_DB_URL 保持一致
PGVECTOR_PASSWORD=change-me
# 向量维度，必须和当前使用的 embedding 模型输出维度一致
VECTOR_DIMENSION=1536
# Elasticsearch 地址列表，多个节点可用英文逗号分隔
ES_HOSTS=http://127.0.0.1:9200
# Elasticsearch 中存放知识分片的索引名称
ES_INDEX=knowledge_chunks
# Elasticsearch 用户名，未开启鉴权时可留空
ES_USERNAME=elastic
# Elasticsearch 密码，未开启鉴权时可留空
ES_PASSWORD=change-me
# Elasticsearch 请求超时时间，单位毫秒
ES_TIMEOUT_MS=5000
# Kibana 连接 Elasticsearch 使用的内置账号密码，由 docker-compose 的 kibana-setup 自动写入 ES
KIBANA_SYSTEM_PASSWORD=change-me
# Kibana 本地开发加密 Key，生产环境请改成随机 32 位以上字符串
KIBANA_SECURITY_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
KIBANA_SAVED_OBJECTS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
KIBANA_REPORTING_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# MinIO 服务地址，通常填写 host:port
MINIO_ENDPOINT=127.0.0.1:9000
# MinIO 访问账号，用于上传和读取知识库文件
MINIO_ACCESS_KEY=minioadmin
# MinIO 访问密钥，用于上传和读取知识库文件
MINIO_SECRET_KEY=change-me
# MinIO 中存放业务文件的桶名称
MINIO_BUCKET=ai-love

# 主聊天模型提供方标识，决定走哪个 LLM Provider
LLM_PROVIDER=xai_router
# 主模型服务的 OpenAI 兼容基础地址
LLM_BASE_URL=https://api.xairouter.com/v1
# 主聊天模型名称，生成回复时默认使用这个模型
LLM_MODEL=gpt-5
# Token 统计后端，支持 auto / tiktoken / huggingface / char_estimate
TOKENIZER_BACKEND=auto
# HuggingFace tokenizer 仓库名，仅在 tokenizer_backend=huggingface 时需要
HF_TOKENIZER_REPO=
# xAI Router 的 API Key，仅在使用 xai_router 提供方时需要
XAI_API_KEY=

# DeepSeek 低成本结构化分析模型：长期记忆提取默认走这个模型，不占用主聊天模型
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# RocketMQ：长期记忆提取事件队列；Redis 仍使用远程服务器，不在 docker-compose 中启动
ROCKETMQ_NAMESRV_ADDR=127.0.0.1:9876
ROCKETMQ_PRODUCER_GROUP=ai_love_memory_producer
ROCKETMQ_MEMORY_TOPIC=ai_love_memory_extraction
ROCKETMQ_MEMORY_TAG=memory.extract.v1
ROCKETMQ_MEMORY_CONSUMER_GROUP=ai_love_memory_consumer
ROCKETMQ_SEND_TIMEOUT_MS=3000
ROCKETMQ_MAX_RECONSUME_TIMES=16

# 是否启用 LangSmith 集成，false 表示完全不接入
LANGSMITH_ENABLED=true
# 是否上报链路追踪到 LangSmith，false 表示只本地运行不追踪
LANGSMITH_TRACING=true
# LangSmith API Key，用于鉴权和上报 trace
LANGSMITH_API_KEY=your-langsmith-api-key
# LangSmith 项目名，方便在控制台按项目隔离查看链路
LANGSMITH_PROJECT=project-ai
# LangSmith 服务地址，默认使用官方云端地址
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LangSmith 工作区 ID，可选，未区分工作区时可留空
LANGSMITH_WORKSPACE_ID=
# LangSmith 采样率，范围 0 到 1，1.0 表示全部上报
LANGSMITH_SAMPLE_RATE=1.0
# LangSmith 隐私模式开关，true 隐藏输入输出并脱敏，false 可查看完整链路内容
LANGSMITH_PRIVACY_MODE=true
# 聊天回复 Prompt 的 LangSmith 标识，可选，未使用远端 Prompt 时留空
LANGSMITH_PROMPT_CHAT_REPLY=
# 记忆决策 Prompt 的 LangSmith 标识，可选，未使用远端 Prompt 时留空
LANGSMITH_PROMPT_MEMORY_DECISION=

# OpenAI API Key，仅在切换到 OpenAI 兼容提供方或相关能力时需要
OPENAI_API_KEY=
# OpenAI 服务基础地址，直连官方或代理时都从这里配置
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI 默认模型名，仅在使用 OpenAI Provider 时生效
OPENAI_MODEL=gpt-4.1

# Embedding 模型名称，用于知识切片向量化
EMBEDDING_MODEL=text-embedding-3-small
# Embedding 批处理大小，值越大吞吐越高但单次请求更重
EMBEDDING_BATCH_SIZE=32
# 重排服务地址，RAG 检索结果会调用它做 rerank
RERANK_SERVICE_URL=http://127.0.0.1:8001
# 重排服务鉴权 Key，可选，服务未开启鉴权时可留空
RERANK_API_KEY=
# 调用重排服务的超时时间，单位毫秒
RERANK_TIMEOUT_MS=5000
# 向量召回候选数量，值越大召回更广但成本更高
HYBRID_DENSE_TOP_K=20
# BM25 词法召回候选数量，值越大召回更广但噪音也可能更多
HYBRID_BM25_TOP_K=20
# 双路融合后保留的候选数量，用于后续重排
HYBRID_FUSION_TOP_K=12
# 最终放入 Prompt 的父级上下文数量，影响回复参考材料多少
PROMPT_PARENT_TOP_K=4
# 重排后最终保留的 TopN 结果数量
RERANK_TOP_N=5
# HuggingFace 镜像地址，可选，国内网络受限时可配置
HF_ENDPOINT=

# 是否启用 LangGraph Checkpointer，true 会保留工作流状态检查点
LANGGRAPH_USE_CHECKPOINTER=true
# LangGraph 检查点存储地址，可选，未接外部存储时可留空
LANGGRAPH_CHECKPOINT_URL=

# MCP 工具调用是否需要审批，true 表示执行前需要确认
MCP_REQUIRE_APPROVAL=false
# 是否启用 Tavily 搜索相关 MCP 能力
MCP_TAVILY_ENABLED=true
# 是否启用高德地图相关 MCP 能力
MCP_AMAP_ENABLED=false
# MCP 传输协议类型，当前项目默认使用 streamable_http
MCP_TRANSPORT=streamable_http
# Tavily API Key，启用 Tavily 搜索时需要填写
TAVILY_API_KEY=
# 高德地图 API Key，启用地图能力时需要填写
AMAP_MAPS_API_KEY=
# 高德 MCP 服务地址，后端会通过它访问地图工具
AMAP_MCP_URL=http://127.0.0.1:3100/mcp
# 高德 MCP 额外请求头 JSON，可选，需要网关鉴权时填写
AMAP_MCP_HEADERS_JSON=

# 是否启用自定义接口 API Key 鉴权，true 时请求必须带鉴权头
API_KEY_ENABLED=false
# 自定义接口 API Key 的具体值，启用鉴权时需要填写
API_KEY_VALUE=

# QQ邮箱配置
# QQ 邮箱账号，可选，用于发送邮件通知时作为发件人
QQ_EMAIL=your-email@example.com
# QQ 邮箱授权码，可选，不是登录密码而是 SMTP 授权码
QQ_EMAIL_PASSWORD=your-smtp-authorization-code
